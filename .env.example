# ── Claude Code Sandbox Environment Variables ──────────────
# Rename this file to .env and fill in the values you need.
# This file will be automatically loaded into the container.

# GitHub Personal Access Token (for gh CLI, private repos, etc.)
GITHUB_PERSONAL_ACCESS_TOKEN=

# Anthropic API Key (if using Claude API directly)
ANTHROPIC_API_KEY=

# Custom environment variables for your project
# MY_API_KEY=
# DATABASE_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=